{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(**/*_secret*)",
      "Read(**/*credentials*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(/etc/shadow)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "excludedCommands": [
      "git",
      "pytest",
      "python",
      "uv",
      "ruff"
    ]
  },
  "env": {
    "PYTHONPATH": "${workspaceFolder}/src"
  }
}
